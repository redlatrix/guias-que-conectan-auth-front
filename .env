# API de autenticación (ya configurada con proxy en vite.config.ts)
# VITE_API_URL se usa como baseURL del axio principal (src/services/api.ts)
# En desarrollo, el proxy de Vite redirige /api → https://auth.guiasqueconectan.ml-ware.com
VITE_API_URL=/api

# API del core (generador de guías) — corre localmente en puerto 3001
VITE_CORE_API_URL=http://localhost:3001/api
